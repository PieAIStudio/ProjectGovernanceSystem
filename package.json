{
  "name": "pro-gov",
  "private": true,
  "version": "0.3.14",
  "description": "Public upstream for AI-assisted project documentation governance, agent routing, and workflow profiles.",
  "packageManager": "pnpm@11.9.0",
  "type": "module",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "doc-gov": "node packages/doc-gov/dist/cli.js",
    "pro-gov": "node packages/pro-gov/dist/cli.js",
    "build": "pnpm --filter @pieai/doc-gov build && pnpm --filter @pieai/pro-gov build",
    "test": "pnpm --filter @pieai/doc-gov test && pnpm --filter @pieai/pro-gov test",
    "test:package-consumer": "node scripts/smoke-packed-consumer.mjs",
    "typecheck": "pnpm --filter @pieai/doc-gov typecheck && pnpm --filter @pieai/pro-gov typecheck"
  },
  "devDependencies": {
    "lefthook": "^2.1.9"
  }
}
